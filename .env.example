# Analytics configuration for meethemind.com
#
# Copy this file to ".env" and fill in your IDs. These are PUBLIC identifiers
# (they ship in the client bundle), so they are not secrets — but .env is
# gitignored so you can keep per-environment values out of the repo.
#
# Until a value is present, that provider stays completely dark (no script
# loads, no tracking fires).

# Google Analytics 4 — Measurement ID, found in GA under
# Admin → Data streams → your web stream. Looks like: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=

# LinkedIn Insight Tag — Partner ID, found in LinkedIn Campaign Manager under
# Analyze → Insight Tag. Numeric, e.g. 1234567
VITE_LINKEDIN_PARTNER_ID=
